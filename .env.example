# LLM — set one key; provider is auto-detected (deepseek takes priority if both are set)
# Option A: Anthropic
ANTHROPIC_API_KEY=
# NORMALIZATION_MODEL=claude-sonnet-5

# Option B: DeepSeek (OpenAI-compatible)
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# NORMALIZATION_MODEL=deepseek-chat

# Override provider explicitly if needed
# LLM_PROVIDER=anthropic   # or deepseek

# Database (defaults to SQLite for local use)
# DATABASE_URL=sqlite:///./ichat.db
# DATABASE_URL=postgresql://user:password@localhost/ichat

# Workspace
DEFAULT_WORKSPACE_ID=1

# Source directories (auto-detected if not set)
# CLAUDE_CODE_DIR=~/.claude/projects
# COPILOT_DIR=~/.../Code/User/workspaceStorage

# Archive
# ARCHIVE_DIR=./archive/raw

# API server (Phase 4 — FastAPI)
# JWT_SECRET=change-me-to-a-long-random-string-in-production
# JWT_EXPIRE_HOURS=24
# API_HOST=127.0.0.1
# API_PORT=8000

# Semantic search (Phase 5 — embeddings via OpenAI)
# OPENAI_API_KEY=sk-...
# EMBEDDING_MODEL=text-embedding-3-small
